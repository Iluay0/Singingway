{
  "Lines": [
    { "Time": "00:00.00", "Text": "(Instrumental)" },
	
    { "Time": "00:12.05", "Text": "Oh, twin gods, bless this land" },
    { "Time": "00:15.40", "Text": "To us treasure bestow" },
    { "Time": "00:18.87", "Text": "City of desert sands" },
    { "Time": "00:22.12", "Text": "Water and gold below" },
	
    { "Time": "00:25.68", "Text": "Lifeblood and rubies red" },
    { "Time": "00:29.02", "Text": "Precious coins cast aglow" },
    { "Time": "00:32.52", "Text": "Four hands our fortunes mend" },
    { "Time": "00:35.85", "Text": "That want we may not know" },
	
    { "Time": "00:39.13", "Text": "And when we reach our ends" },
    { "Time": "00:42.68", "Text": "To scales we gladly go" },
    { "Time": "00:46.11", "Text": "Our fates are yours to bend" },
    { "Time": "00:49.67", "Text": "To hells and heavens flow" },
	
    { "Time": "00:53.07", "Text": "Under arid sky" },
    { "Time": "00:56.36", "Text": "With silk veils we weave a rainbow" },
    { "Time": "00:59.77", "Text": "Voices lifted high" },
    { "Time": "01:02.91", "Text": "Dreams upon our backs we carry" },
	
    { "Time": "01:06.07", "Text": "When day beckons night" },
    { "Time": "01:10.09", "Text": "As does restless time we never slow" },
    { "Time": "01:13.58", "Text": "Trusting hand in hand" },
    { "Time": "01:16.43", "Text": "Life, death will follow" },
	
    { "Time": "01:22.19", "Text": "" },
	
    { "Time": "01:23.76", "Text": "Stoke now nascent flamе" },
    { "Time": "01:28.31", "Text": "Brighter burn" },
    { "Time": "01:30.75", "Text": "Dance with souls afire" },
    { "Time": "01:33.25", "Text": "May ember catch and red-gold spark" },
    { "Time": "01:38.17", "Text": "Rise to new heights" },
	
    { "Time": "01:42.79", "Text": "May we want for naught coin can buy" },
    { "Time": "01:47.41", "Text": "Never see wealth′s river dry" },
    { "Time": "01:51.95", "Text": "May we find fortune after life" },
    { "Time": "01:55.64", "Text": "For this we pray" },
    { "Time": "01:57.84", "Text": "We pray" },
