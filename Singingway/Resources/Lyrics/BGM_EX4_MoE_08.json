{
  "Lines": [
    { "Time": "00:00.00", "Text": "(Oh at fair moon's rise" },
    { "Time": "00:01.95", "Text": "Into the night fly" },
    { "Time": "00:03.92", "Text": "Follow the moonlight" },
    { "Time": "00:05.93", "Text": "Fear not what you find)" },

    { "Time": "00:07.81", "Text": "(Instrumental)" },

    { "Time": "00:15.90", "Text": "(O heart's desire" },
    { "Time": "00:17.91", "Text": "Join now our choir" },
    { "Time": "00:19.95", "Text": "For love conspire" },
    { "Time": "00:21.89", "Text": "Go, chase it higher)" },

    { "Time": "00:23.91", "Text": "(Instrumental)" },

    { "Time": "00:31.77", "Text": "Through the silent woods tonight" },
    { "Time": "00:33.70", "Text": "I am guided by moonlight" },
    { "Time": "00:35.67", "Text": "For the first time so alone fearing no shadow" },
    { "Time": "00:39.60", "Text": "Like my mother before me I follow this path" },
    { "Time": "00:43.35", "Text": "Knowing love will find me" },

    { "Time": "00:47.75", "Text": "She will hear my song tonight" },
    { "Time": "00:49.62", "Text": "Dedicated to moonlight" },
    { "Time": "00:51.62", "Text": "See that I'm a woman grown enough for secrets" },

    { "Time": "00:55.55", "Text": "Like my grandmother before me" },
    { "Time": "00:57.68", "Text": "I know each note, every beat" },
    { "Time": "01:00.65", "Text": "Melody mine to keep" },

    { "Time": "01:03.93", "Text": "(Go, sing now unto the sky)" },
    { "Time": "01:07.46", "Text": "(Girls are born to step into the light)" },

    { "Time": "01:11.62", "Text": "O wide open midnight sky" },
    { "Time": "01:15.35", "Text": "Please carry my voice aloft" },
    { "Time": "01:17.33", "Text": "Far away where she waits" },
    { "Time": "01:18.83", "Text": "Lover's moon" },
    { "Time": "01:21.69", "Text": "(Ooh, Moon)" },

    { "Time": "01:23.77", "Text": "Fairest goddess wandering the night" },
    { "Time": "01:27.69", "Text": "In your name we bare our hearts" },
    { "Time": "01:29.64", "Text": "With your grace will our passion take flight" },
    { "Time": "01:31.98", "Text": "We would keep your song alive" },
    { "Time": "01:35.46", "Text": "Shrouded safe in soft moonlight" },

    { "Time": "01:39.93", "Text": "Maiden goddess of heavens above" },
    { "Time": "01:43.63", "Text": "In your name we share our hearts" },
    { "Time": "01:45.66", "Text": "With your grace will our prayer become" },
    { "Time": "01:48.01", "Text": "Solace, shelter, hope and love" },
    { "Time": "01:51.44", "Text": "Greater than the tales sing of" },
    { "Time": "01:57.42", "Text": "Oh, love" },

    { "Time": "01:59.86", "Text": "(Instrumental)" },

    { "Time": "02:02.18", "Text": "(Songbirds of night" },
    { "Time": "02:04.24", "Text": "Passion take flight" },
    { "Time": "02:06.06", "Text": "Oooooh..." },
    { "Time": "02:10.01", "Text": "Silver and white" },
    { "Time": "02:11.97", "Text": "Forest moonlight" },
    { "Time": "02:14.03", "Text": "Oooooh..." },
    { "Time": "02:18.07", "Text": "This world we share" },
    { "Time": "02:20.03", "Text": "With you through prayer" },
    { "Time": "02:22.04", "Text": "Oooooh..." },
    { "Time": "02:25.94", "Text": "Love for you)" },
	
    { "Time": "02:32.05", "Text": "", "LoopToTime": "00:00.00" }
  ]
}