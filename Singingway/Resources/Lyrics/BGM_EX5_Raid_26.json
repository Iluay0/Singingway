    { "Time": "04:19.00", "Text": "Join the crowd! (Yeah)" },
	
    { "Time": "04:21.00", "Text": "Lift your soul! (Yeah)" },
    { "Time": "04:23.00", "Text": "All the rights that you tout are wrong" },
    { "Time": "04:26.00", "Text": "Tell me yes! (Yeah)" },
    { "Time": "04:28.00", "Text": "Just believe! (Yeah)" },
    { "Time": "04:30.00", "Text": "Don't defy my authority" },
    { "Time": "04:33.00", "Text": "Burn to ashes in your struggle" },
    { "Time": "04:36.00", "Text": "By royal decree!" },
	
