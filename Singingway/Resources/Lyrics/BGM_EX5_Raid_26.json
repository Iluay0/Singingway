{
  "Lines": [
    { "Time": "00:00.00", "Text": "(Instrumental)" },
	
    { "Time": "00:14.00", "Text": "Long live the king!" },
    { "Time": "00:16.20", "Text": "He will come and rise to the fight" },
    { "Time": "00:21.00", "Text": "Arcadion!" },
    { "Time": "00:23.75", "Text": "Protected by his almighty right" },
	
    { "Time": "00:28.00", "Text": "Hear the people clamor, callin' my name" },
    { "Time": "00:31.50", "Text": "Chanting so enamored, blind to their pain" },
    { "Time": "00:35.50", "Text": "Every hope they harbor, mine to obtain" },
    { "Time": "00:38.00", "Text": "As their liege, now make way" },
    { "Time": "00:42.00", "Text": "Honor won by glory, blood in the sand" },
    { "Time": "00:46.00", "Text": "Strength, the only justice worthy of man" },
    { "Time": "00:49.50", "Text": "Try to overcome me, but in the end" },
    { "Time": "00:52.25", "Text": "You will kneel, I will stand" },
	
    { "Time": "00:56.00", "Text": "Long live the king!" },
    { "Time": "00:59.00", "Text": "He will come and rise to the fight" },
    { "Time": "01:04.00", "Text": "Arcadion!" },
    { "Time": "01:06.25", "Text": "Protected by his almighty right" },
	
    { "Time": "01:11.00", "Text": "Hear thе people clamor, lauding my faith" },
    { "Time": "01:14.00", "Text": "Writing history to sanction my reign" },
    { "Time": "01:18.00", "Text": "Souls thе finest fodder, so what remains" },
    { "Time": "01:21.00", "Text": "Reap in wealth what you crave" },
    { "Time": "01:25.00", "Text": "Hark the gong of battle, this should amuse" },
    { "Time": "01:28.25", "Text": "Guilty however I deign to choose" },
    { "Time": "01:32.00", "Text": "Sing your indignation, shout and accuse" },
    { "Time": "01:35.00", "Text": "I will win, you will lose" },
	
    { "Time": "01:39.00", "Text": "Long live the king!" },
    { "Time": "01:42.00", "Text": "He will come and rise to the fight" },
    { "Time": "01:46.00", "Text": "Arcadion!" },
    { "Time": "01:49.00", "Text": "Protected by his almighty right" },
	
    { "Time": "01:53.00", "Text": "Those who claim liberty" },
    { "Time": "01:57.00", "Text": "Those who claim revolution" },
    { "Time": "01:59.50", "Text": "Those who dare challenge me" },
    { "Time": "02:04.00", "Text": "All will fall to my blade!" },
    { "Time": "02:08.00", "Text": "For your dignity" },
    { "Time": "02:11.00", "Text": "Bow to our domination" },
    { "Time": "02:14.00", "Text": "Rebels and libertines" },
    { "Time": "02:18.00", "Text": "Shut up and know your place!" },
	
    { "Time": "02:21.00", "Text": "We will rise! (Yeah)" },
    { "Time": "02:23.00", "Text": "They will break! (Yeah)" },
    { "Time": "02:25.00", "Text": "We will seize all that we can take" },
    { "Time": "02:28.00", "Text": "Close your eyes! (Yeah)" },
    { "Time": "02:30.00", "Text": "Hold your tongue! (Yeah)" },
    { "Time": "02:32.00", "Text": "Cease your fight 'til our deeds are done" },
    { "Time": "02:35.00", "Text": "I am law! (Yeah)" },
    { "Time": "02:37.00", "Text": "I am great! (Yeah)" },
    { "Time": "02:39.00", "Text": "You're a mortal, not born to fame" },
    { "Time": "02:43.00", "Text": "Kiss the ring! (Yeah)" },
    { "Time": "02:44.75", "Text": "Bend the knee! (Yeah)" },
    { "Time": "02:46.50", "Text": "Don't defy what is plenary" },
    { "Time": "02:50.00", "Text": "State your mind with dreams of grandeur" },
	{ "Time": "02:53.00", "Text": "And go back to sleep!" },
	
	{ "Time": "02:56.00", "Text": "(Instrumental)" },
	
    { "Time": "03:08.00", "Text": "Long live the king!" },
    { "Time": "03:11.00", "Text": "He will come and rise to the fight" },
    { "Time": "03:15.00", "Text": "Arcadion!" },
    { "Time": "03:17.00", "Text": "Protected by his almighty right" },
	
    { "Time": "03:22.00", "Text": "Countless have I conquered, taught to obey" },
    { "Time": "03:25.00", "Text": "Show me loyalty and pain goes away" },
    { "Time": "03:29.00", "Text": "I will not surrender, beaten or fade" },
    { "Time": "03:32.00", "Text": "Make a choice, make my day" },
    { "Time": "03:36.00", "Text": "Heavy lies the crown, or so say the weak" },
    { "Time": "03:40.00", "Text": "Absolute control is my destiny" },
    { "Time": "03:44.00", "Text": "I taste only power, never defeat" },
    { "Time": "03:47.00", "Text": "Fear the throne, so supreme" },
		
    { "Time": "03:51.00", "Text": "Long live the king!" },
    { "Time": "03:53.25", "Text": "He will come and rise to the fight" },
    { "Time": "03:58.00", "Text": "Arcadion!" },
    { "Time": "04:00.00", "Text": "Usurpers will be crushed by his might" },
	
    { "Time": "04:04.00", "Text": "We will rise! (Yeah)" },
    { "Time": "04:06.00", "Text": "They will break! (Yeah)" },
	{ "Time": "04:08.00", "Text": "We will seize all that we can take" },
